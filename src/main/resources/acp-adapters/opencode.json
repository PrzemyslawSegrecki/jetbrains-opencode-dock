{
  "id": "opencode",
  "name": "OpenCode",
  "iconPath": "/icons/opencode.svg",
  "iconPathLight": "/icons/opencode-light.svg",
  "iconPathDark": "/icons/opencode_dark.svg",
  "distribution": {
    "type": "system",
    "version": "system"
  },
  "systemExecutable": {
    "win": "opencode.cmd",
    "unix": "opencode"
  },
  "preferSystemExecutable": true,
  "args": [
    "acp"
  ],
  "cli": {
    "executable": {
      "win": "opencode.cmd",
      "unix": "opencode"
    },
    "resumeArgs": [
      "--session",
      "{sessionId}"
    ]
  },
  "authConfig": {
    "uiMode": "manage_terminal",
    "loginMode": "manage_terminal"
  },
  "disabledModels": [
    "gpt-5.1",
    "gpt-5.2"
  ]
}
